              "type": "string"
            },
            {
              "id": "e21eac83-0d48-4e16-bf27-cc0b33298ec3",
              "name": "hashtags",
              "value": "={{ ($json.output.tags_and_reach_play.hashtags || []).join(', ') }}",
              "type": "string"
            },
            {
              "id": "f665722e-764d-47cb-b714-b59d0d6d64b6",
              "name": "best_audience",
