              "id": "482c357a-e352-4adc-8b87-e102d2f6668e",
              "name": "hook_used",
              "value": "={{ $json.output.hook_options.analytical }}",
              "type": "string"
            },
            {
              "id": "63e76e46-d8d8-4e47-95da-f3251ada6480",
              "name": "linkedin_post_preview",
              "value": "={{ $json.output.hook_options.analytical + '\\n\\n' + $json.output.master_repost.opening + '\\n\\n• ' + ($json.output.master_repost.breakdown_bullets || []).join('\\n• ') + '\\n\\n' + $json.output.master_repost.abdul_insight + '\\n\\n' + $json.output.master_repost.opportunity_signal + '\\n\\n' + $json.output.master_repost.appreciation + '\\n\\n' + $json.output.master_repost.cta + '\\n\\n' + ($json.output.tags_and_reach_play.hashtags || []).join(' ') }}",
